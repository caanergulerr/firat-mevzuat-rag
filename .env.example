# ===== Fırat Mevzuat RAG - Ortam Değişkenleri =====
# Bu dosyayı kopyalayıp .env olarak kaydedin ve değerleri doldurun.

# LLM API (birini seçin)
OPENAI_API_KEY=sk-...
# GOOGLE_API_KEY=...

# Embedding Modeli
EMBEDDING_MODEL=dbmdz/bert-base-turkish-cased
EMBEDDING_DEVICE=cpu

# ChromaDB
CHROMA_DB_PATH=./chroma_db
CHROMA_COLLECTION_NAME=firat_mevzuat

# Retrieval
TOP_K_RESULTS=5

# API Server
API_HOST=0.0.0.0
API_PORT=8000
DEBUG=True
